<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.FluxoCaixa" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOutline">@color/outline</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>
        <item name="materialButtonStyle">@style/Widget.FluxoCaixa.Button</item>
        <item name="textInputStyle">@style/Widget.FluxoCaixa.TextInputLayout</item>
    </style>

    <style name="Widget.FluxoCaixa.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="Widget.FluxoCaixa.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">52dp</item>
    </style>

    <style name="Widget.FluxoCaixa.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="hintEnabled">true</item>
        <item name="boxStrokeColor">@color/input_stroke_color</item>
        <item name="boxBackgroundColor">@color/surface</item>
    </style>

    <style name="Widget.FluxoCaixa.FilterChip" parent="Widget.Material3.Button.TextButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:textSize">13sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="backgroundTint">@null</item>
    </style>

    <style name="TextAppearance.FluxoCaixa.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.FluxoCaixa.Subtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/on_surface_variant</item>
    </style>
</resources>
