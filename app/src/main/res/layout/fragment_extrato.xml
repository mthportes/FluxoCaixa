<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollExtratoHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:fillViewport="false"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_screen_horizontal"
            android:paddingTop="@dimen/spacing_screen_vertical"
            android:paddingEnd="@dimen/spacing_screen_horizontal"
            android:paddingBottom="4dp">

            <include
                android:id="@+id/assistente"
                layout="@layout/layout_assistant" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_gradient_saldo"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:letterSpacing="0.06"
                        android:text="@string/label_saldo"
                        android:textAllCaps="true"
                        android:textColor="#D1FAE5"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textSaldo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:maxLines="1"
                        android:text="R$ 0,00"
                        android:textColor="@color/on_primary"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        app:autoSizeMaxTextSize="28sp"
                        app:autoSizeMinTextSize="18sp"
                        app:autoSizeStepGranularity="2sp"
                        app:autoSizeTextType="uniform" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutFiltro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonFiltroTodos"
                    style="@style/Widget.FluxoCaixa.FilterChip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_filter_todos_selected"
                    android:text="@string/filtro_todos"
                    android:textColor="@color/primary_dark"
                    app:backgroundTint="@null"
                    app:rippleColor="#3314B8A6" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonFiltroReceita"
                    style="@style/Widget.FluxoCaixa.FilterChip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_filter_chip"
                    android:text="@string/filtro_receita"
                    android:textColor="@color/on_surface_variant"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_receita"
                    app:iconGravity="textStart"
                    app:iconPadding="4dp"
                    app:iconSize="16dp"
                    app:iconTint="@color/receita_dark"
                    app:rippleColor="#3310B981" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonFiltroDespesa"
                    style="@style/Widget.FluxoCaixa.FilterChip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_filter_chip"
                    android:text="@string/filtro_despesa"
                    android:textColor="@color/on_surface_variant"
                    app:backgroundTint="@null"
                    app:icon="@drawable/ic_despesa"
                    app:iconGravity="textStart"
                    app:iconPadding="4dp"
                    app:iconSize="16dp"
                    app:iconTint="@color/despesa_dark"
                    app:rippleColor="#33EF4444" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerLancamentos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="@dimen/spacing_screen_horizontal"
        android:paddingTop="8dp"
        android:paddingEnd="@dimen/spacing_screen_horizontal"
        android:paddingBottom="@dimen/spacing_screen_vertical"
        android:scrollbars="vertical" />

    <LinearLayout
        android:id="@+id/layoutVazio"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/textListaVazia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/lista_vazia"
            android:textColor="@color/on_surface"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textListaVaziaDica"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/lista_vazia_dica"
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
