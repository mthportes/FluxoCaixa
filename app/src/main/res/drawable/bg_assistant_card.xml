<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#E0F2FE"
                android:startColor="#ECFEFF"
                android:type="linear" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#99A5F3FC" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <item
        android:gravity="top|end"
        android:right="12dp"
        android:top="12dp">
        <shape android:shape="oval">
            <size
                android:width="72dp"
                android:height="72dp" />
            <gradient
                android:endColor="#00A5F3FC"
                android:gradientRadius="36dp"
                android:startColor="#66A5F3FC"
                android:type="radial" />
        </shape>
    </item>
</layer-list>
